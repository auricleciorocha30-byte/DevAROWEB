rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'admin@admin.com' || 
        request.auth.token.email == 'auricleciorocha30@gmail.com'
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidCategory(data) {
      return data.keys().hasAll(['name']) && 
             data.keys().size() == 1 &&
             data.name is string && data.name.size() <= 100 && data.name.size() > 0;
    }

    function isValidAsset(data) {
      return data.keys().hasAll(['type', 'url', 'title', 'category', 'created_at']) &&
             data.keys().size() == 5 &&
             data.type is string && (data.type == 'photo' || data.type == 'video') &&
             data.url is string && data.url.size() <= 1000000 && 
             data.title is string && data.title.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.created_at is number;
    }

    function isValidSetting(data) {
      let isWhatsAppValid = !data.keys().hasAny(['whatsapp']) || (data.whatsapp is string && data.whatsapp.size() <= 50);
      let isLogoValid = !data.keys().hasAny(['logo_url']) || (data.logo_url is string && data.logo_url.size() <= 1000000);
      return data.keys().size() <= 2 && isWhatsAppValid && isLogoValid;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'contact', 'created_at']) &&
             data.keys().size() == 3 &&
             data.name is string && data.name.size() <= 200 &&
             data.contact is string && data.contact.size() <= 200 &&
             data.created_at is number;
    }

    match /categories/{categoryId} {
      allow list: if true;
      allow get: if true;
      allow create: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
      allow update: if false; // Not needed
      allow delete: if isAdmin() && isValidId(categoryId);
    }

    match /assets/{assetId} {
      allow list: if true;
      allow get: if true;
      allow create: if isAdmin() && isValidId(assetId) && isValidAsset(incoming());
      allow update: if false;
      allow delete: if isAdmin() && isValidId(assetId);
    }

    match /settings/{settingId} {
      allow list: if true;
      allow get: if true;
      allow create: if isAdmin() && isValidId(settingId) && isValidSetting(incoming());
      allow update: if isAdmin() && isValidId(settingId) && isValidSetting(incoming());
      allow delete: if false;
    }

    match /leads/{leadId} {
      allow create: if isValidId(leadId) && isValidLead(incoming());
      allow list: if isAdmin();
      allow get: if isAdmin();
      allow update, delete: if false;
    }
  }
}
