{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Category for portfolio assets",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Asset": {
      "title": "Asset",
      "description": "Media asset for the portfolio",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["photo", "video"] },
        "url": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "created_at": { "type": "number", "description": "Timestamp" }
      },
      "required": ["type", "url", "title", "category", "created_at"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Configuration values",
      "type": "object",
      "properties": {
        "whatsapp": { "type": "string" },
        "logo_url": { "type": "string" }
      }
    },
    "Lead": {
      "title": "Lead",
      "description": "Contact submitted by a client",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "created_at": { "type": "number", "description": "Timestamp" }
      },
      "required": ["name", "contact", "created_at"]
    }
  },
  "firestore": {
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Categories for assets"
    },
    "assets/{assetId}": {
      "schema": "Asset",
      "description": "Media items in the portfolio"
    },
    "settings/{settingId}": {
      "schema": "Setting",
      "description": "App settings (usually a single document 'global')"
    },
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Leads from potential customers"
    }
  }
}
